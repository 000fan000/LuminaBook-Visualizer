# Public browser configuration. These values are safe to expose by design.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudflare Pages Function secrets. Configure these in Cloudflare, not in this file.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# PLATFORM_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# PLATFORM_LLM_API_KEY=YOUR_PLATFORM_PROVIDER_KEY
# PLATFORM_LLM_MODEL=gpt-4.1-mini
# Optional pricing inputs used by the admin cost estimate.
# PLATFORM_LLM_INPUT_USD_PER_MILLION=0.40
# PLATFORM_LLM_OUTPUT_USD_PER_MILLION=1.60
